# ============================================================
# Configurações de Autenticação SharePoint (Azure AD App Registration)
# ============================================================
# Para obter essas credenciais:
# 1. Acesse https://portal.azure.com
# 2. Vá em "Azure Active Directory" > "App registrations" > "New registration"
# 3. Registre o app e copie o Client ID e Tenant ID
# 4. Em "Certificates & secrets", crie um novo Client Secret
# 5. Em "API permissions", adicione "SharePoint > Sites.ReadWrite.All" (Application)
# 6. Clique em "Grant admin consent"
# ============================================================

SHAREPOINT_SITE_URL=https://xploredados.sharepoint.com/sites/Produto-BI
SHAREPOINT_CLIENT_ID=seu_client_id_aqui
SHAREPOINT_CLIENT_SECRET=seu_client_secret_aqui
SHAREPOINT_TENANT_ID=seu_tenant_id_aqui
SHAREPOINT_FOLDER_PATH=transparencia_servidores_executivo_federal
